generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model DataLookup {
  id                  String              @id @default(uuid())
  index               Int
  type                String
  category            String
  description         String
  isDefault           Boolean
  value               String              @unique
  note                String              @db.Text
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  regions             CouncilFellowship[] @relation("RegionLookup")
  memberPreviousTypes Member[]            @relation("MemberPreviousType")
  memberRegions       Member[]            @relation("MemberRegion")
  memberStates        Member[]            @relation("MemberState")
  memberTypes         Member[]            @relation("MemberType")
  memberCategories    Member[]            @relation("MemberCategoryLookup")
  reports             Report[]            @relation("ReportStatusLookup")
  roleStates          Role[]              @relation("RoleStateLookup")
  roleTypes           Role[]              @relation("RoleTypeLookup")
  states              Staff[]             @relation("StateLookup")
}

model Permission {
  id          String   @id @default(uuid())
  codeName    String   @unique
  description String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  roles       Role[]   @relation("PermissionToRole")
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String       @db.Text
  typeId      String
  stateId     String
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  state       DataLookup   @relation("RoleStateLookup", fields: [stateId], references: [id])
  type        DataLookup   @relation("RoleTypeLookup", fields: [typeId], references: [id])
  staffs      Staff[]
  permissions Permission[] @relation("PermissionToRole")

  @@index([stateId], map: "Role_stateId_fkey")
  @@index([typeId], map: "Role_typeId_fkey")
}

model Member {
  id                    String            @id @default(uuid())
  name                  String            @unique
  certificateNo         String            @unique
  certificateIssuedDate DateTime
  isInEthiopia          Boolean
  country               String
  city                  String?
  subcity               String?
  zone                  String?
  district              String?
  houseNumber           String?
  phoneNumber           String?
  poBoxNumber           String?
  email                 String?
  councilFellowshipId   String
  typeId                String
  stateId               String
  regionId              String?
  reasonForInactive     String?           @db.Text
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  previousTypeId        String?
  typeChangedAt         DateTime?
  isActive              Boolean           @default(true)
  boardMembers          BoardMember[]
  memberFiles           File[]            @relation("MemberFiles")
  councilFellowship     CouncilFellowship @relation(fields: [councilFellowshipId], references: [id])
  previousType          DataLookup?       @relation("MemberPreviousType", fields: [previousTypeId], references: [id])
  region                DataLookup?       @relation("MemberRegion", fields: [regionId], references: [id])
  state                 DataLookup        @relation("MemberState", fields: [stateId], references: [id])
  type                  DataLookup        @relation("MemberType", fields: [typeId], references: [id])
  reports               Report[]
  memberCategoryId      String?
  memberCategory        DataLookup?       @relation("MemberCategoryLookup", fields: [memberCategoryId], references: [id])

  @@index([city])
  @@index([councilFellowshipId])
  @@index([previousTypeId], map: "Member_previousTypeId_fkey")
  @@index([regionId])
  @@index([stateId])
  @@index([typeChangedAt])
  @@index([typeId])
  @@index([memberCategoryId])
}

model BoardMember {
  id                  String             @id @default(uuid())
  memberId            String?
  councilFellowshipId String?
  fullName            String
  phoneNumber         String
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  councilFellowship   CouncilFellowship? @relation(fields: [councilFellowshipId], references: [id])
  member              Member?            @relation(fields: [memberId], references: [id])

  @@index([councilFellowshipId], map: "BoardMember_councilFellowshipId_fkey")
  @@index([memberId], map: "BoardMember_memberId_fkey")
}

model Report {
  id                  String             @id @default(uuid())
  year                Int
  reportedAt          DateTime           @default(now())
  crv                 String?
  file                String?
  remark              String?
  statusId            String
  memberId            String?
  councilFellowshipId String?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  councilFellowship   CouncilFellowship? @relation(fields: [councilFellowshipId], references: [id])
  member              Member?            @relation(fields: [memberId], references: [id])
  status              DataLookup         @relation("ReportStatusLookup", fields: [statusId], references: [id])

  @@unique([councilFellowshipId, year])
  @@unique([memberId, year])
  @@index([statusId], map: "Report_statusId_fkey")
}

model File {
  id                  String             @id @default(uuid())
  fileName            String?
  file                String?
  memberId            String?
  councilFellowshipId String?
  isFromSelamMinster  Boolean?           @default(false)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  councilFellowship   CouncilFellowship? @relation(fields: [councilFellowshipId], references: [id])
  member              Member?            @relation("MemberFiles", fields: [memberId], references: [id])

  @@index([councilFellowshipId], map: "File_councilFellowshipId_fkey")
  @@index([memberId], map: "File_memberId_fkey")
}

model Staff {
  id                     String     @id @default(uuid())
  email                  String     @unique
  fullName               String?
  firstName              String
  lastName               String
  phoneNumber            String?
  password               String
  avatar                 String?
  passwordResetToken     String?
  passwordResetExpiresIn DateTime?
  roleId                 String
  stateId                String
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  role                   Role       @relation(fields: [roleId], references: [id])
  state                  DataLookup @relation("StateLookup", fields: [stateId], references: [id])
  fellowships            StaffFellowship[]

  @@index([roleId], map: "Staff_roleId_fkey")
  @@index([stateId], map: "Staff_stateId_fkey")
}

model CouncilFellowship {
  id                    String        @id @default(uuid())
  name                  String        @unique
  certificateNo         String        @unique
  certificateIssuedDate DateTime
  description           String?
  isInEthiopia          Boolean
  country               String?
  city                  String?
  subcity               String?
  zone                  String?
  district              String?
  houseNumber           String?
  phoneNumber           String?
  poBoxNumber           String?
  email                 String?
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  regionId              String?
  boardMembers          BoardMember[]
  region                DataLookup?   @relation("RegionLookup", fields: [regionId], references: [id])
  files                 File[]
  members               Member[]
  reports               Report[]
  staffLinks            StaffFellowship[]

  @@index([regionId], map: "CouncilFellowship_regionId_fkey")
}

model StaffFellowship {
  id            String           @id @default(uuid())
  staffId       String
  fellowshipId  String
  staff         Staff            @relation(fields: [staffId], references: [id])
  fellowship    CouncilFellowship @relation(fields: [fellowshipId], references: [id])

  @@unique([staffId, fellowshipId])
}
